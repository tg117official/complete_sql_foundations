DROP DATABASE IF EXISTS breakfast_join_db;
CREATE DATABASE breakfast_join_db;
USE breakfast_join_db;

-- =========================================================
-- 1. CREATE TABLES
-- =========================================================

DROP TABLE IF EXISTS breakfast_orders;
CREATE TABLE breakfast_orders (
    oid INT PRIMARY KEY,
    customer_name VARCHAR(100),
    token_color VARCHAR(30),
    order_date DATE,
    qty INT
);

DROP TABLE IF EXISTS token_details;
CREATE TABLE token_details (
    color VARCHAR(30) PRIMARY KEY,
    breakfast VARCHAR(100),
    price DECIMAL(8,2),
    counter_name VARCHAR(100)
);

