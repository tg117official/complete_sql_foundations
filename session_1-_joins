-- =========================================================
-- 4. VIEW DATA
-- =========================================================

SELECT * FROM breakfast_orders;
SELECT * FROM token_details;

-- =========================================================
-- 5. INNER JOIN
-- =========================================================

SELECT *
FROM breakfast_orders bo
INNER JOIN token_details td
    ON bo.token_color = td.color;

-- =========================================================
-- 6. LEFT JOIN
-- =========================================================

SELECT *
FROM breakfast_orders bo
LEFT JOIN token_details td
    ON bo.token_color = td.color;

-- =========================================================
-- 7. RIGHT JOIN
-- =========================================================

SELECT *
FROM breakfast_orders bo
RIGHT JOIN token_details td
    ON bo.token_color = td.color;

-- =========================================================
-- 8. FULL OUTER JOIN (MySQL workaround)
-- =========================================================

SELECT *
FROM breakfast_orders bo
LEFT JOIN token_details td
    ON bo.token_color = td.color

UNION

SELECT *
FROM breakfast_orders bo
RIGHT JOIN token_details td
    ON bo.token_color = td.color;

-- =========================================================
-- 9. LEFT SEMI JOIN EQUIVALENT
-- =========================================================

SELECT bo.*
FROM breakfast_orders bo
WHERE EXISTS (
    SELECT 1
    FROM token_details td
    WHERE bo.token_color = td.color
);

-- =========================================================
-- 10. LEFT ANTI JOIN EQUIVALENT
-- =========================================================

SELECT bo.*
FROM breakfast_orders bo
WHERE NOT EXISTS (
    SELECT 1
    FROM token_details td
    WHERE bo.token_color = td.color
);

-- =========================================================
-- 11. CROSS JOIN
-- =========================================================

SELECT *
FROM breakfast_orders bo
CROSS JOIN token_details td;

-- =========================================================
-- 12. JOIN + FILTER
-- Show only orders where breakfast item is tea or poha
-- =========================================================

SELECT
    bo.oid,
    bo.customer_name,
    bo.token_color,
    td.breakfast,
    td.price,
    bo.qty
FROM breakfast_orders bo
INNER JOIN token_details td
    ON bo.token_color = td.color
WHERE td.breakfast IN ('tea', 'poha');

-- =========================================================
-- 13. JOIN + GROUP BY
-- Count orders by breakfast item
-- =========================================================

SELECT
    td.breakfast,
    COUNT(*) AS total_orders
FROM breakfast_orders bo
INNER JOIN token_details td
    ON bo.token_color = td.color
GROUP BY td.breakfast;

-- =========================================================
-- 14. JOIN + GROUP BY + SUM
-- Total quantity by breakfast item
-- =========================================================

SELECT
    td.breakfast,
    SUM(bo.qty) AS total_qty
FROM breakfast_orders bo
INNER JOIN token_details td
    ON bo.token_color = td.color
GROUP BY td.breakfast;

-- =========================================================
-- 15. JOIN + GROUP BY + HAVING
-- Show breakfast items whose total quantity is more than 5
-- =========================================================

SELECT
    td.breakfast,
    SUM(bo.qty) AS total_qty
FROM breakfast_orders bo
INNER JOIN token_details td
    ON bo.token_color = td.color
GROUP BY td.breakfast
HAVING SUM(bo.qty) > 5;

-- =========================================================
-- 16. JOIN + ORDER BY
-- =========================================================

SELECT
    bo.oid,
    bo.customer_name,
    td.breakfast,
    td.price,
    bo.qty
FROM breakfast_orders bo
INNER JOIN token_details td
    ON bo.token_color = td.color
ORDER BY td.price DESC, bo.customer_name ASC;

-- =========================================================
-- 17. CASE EXPRESSION
-- Categorize quantity
-- =========================================================

SELECT
    oid,
    customer_name,
    token_color,
    qty,
    CASE
        WHEN qty = 1 THEN 'Small'
        WHEN qty BETWEEN 2 AND 3 THEN 'Medium'
        ELSE 'Bulk'
    END AS qty_type
FROM breakfast_orders;

-- =========================================================
-- 18. CASE + JOIN
-- Bill classification
-- =========================================================

SELECT
    bo.oid,
    bo.customer_name,
    td.breakfast,
    td.price,
    bo.qty,
    (td.price * bo.qty) AS total_amount,
    CASE
        WHEN (td.price * bo.qty) < 30 THEN 'Low Bill'
        WHEN (td.price * bo.qty) BETWEEN 30 AND 70 THEN 'Medium Bill'
        ELSE 'High Bill'
    END AS bill_category
FROM breakfast_orders bo
INNER JOIN token_details td
    ON bo.token_color = td.color
ORDER BY total_amount DESC;
