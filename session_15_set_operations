-- =========================================================
-- EXERCISE 1
-- Problem:
-- Show all employees from both branches without duplicate rows.
--
-- Concept:
-- UNION removes duplicate rows.
-- =========================================================
SELECT emp_id, emp_name, department, city, salary
FROM employees_branch_a
UNION
SELECT emp_id, emp_name, department, city, salary
FROM employees_branch_b;

-- =========================================================
-- EXERCISE 2
-- Problem:
-- Show all employees from both branches including duplicate rows.
--
-- Concept:
-- UNION ALL keeps duplicate rows.
