-- =========================================================
-- EXERCISE 15
-- Problem:
-- Show employees who are exactly common in both branches.
--
-- Concept:
-- INTERSECT concept using INNER JOIN.
-- Since same row must be present in both tables, all columns
-- are matched.
-- =========================================================
SELECT a.emp_id, a.emp_name, a.department, a.city, a.salary
FROM employees_branch_a a
INNER JOIN employees_branch_b b
    ON a.emp_id = b.emp_id
   AND a.emp_name = b.emp_name
   AND a.department = b.department
   AND a.city = b.city
   AND a.salary = b.salary;

-- =========================================================
-- EXERCISE 16
-- Problem:
-- Show employees present in branch A but not in branch B.
--
-- Concept:
-- EXCEPT concept using LEFT JOIN.
-- If matching row is not found in branch B, it means
-- that row exists only in branch A.
-- =========================================================
SELECT a.emp_id, a.emp_name, a.department, a.city, a.salary
FROM employees_branch_a a
LEFT JOIN employees_branch_b b
    ON a.emp_id = b.emp_id
   AND a.emp_name = b.emp_name
   AND a.department = b.department
   AND a.city = b.city
   AND a.salary = b.salary
WHERE b.emp_id IS NULL;

-- =========================================================
-- EXERCISE 17
-- Problem:
-- Show employees present in branch B but not in branch A.
--
-- Concept:
-- Reverse of previous exercise.
-- =========================================================
SELECT b.emp_id, b.emp_name, b.department, b.city, b.salary
FROM employees_branch_b b
LEFT JOIN employees_branch_a a
    ON b.emp_id = a.emp_id
   AND b.emp_name = a.emp_name
   AND b.department = a.department
   AND b.city = a.city
   AND b.salary = a.salary
WHERE a.emp_id IS NULL;

-- =========================================================
-- EXERCISE 18
-- Problem:
-- Show departments common in both branches.
--
-- Concept:
-- INTERSECT idea on a single column using INNER JOIN.
-- DISTINCT is used to avoid repeated department names.
-- =========================================================
SELECT DISTINCT a.department
FROM employees_branch_a a
INNER JOIN employees_branch_b b
    ON a.department = b.department;

